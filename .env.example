# pyverdex environment variables. Copy to .env (gitignored) and fill in.
# Secrets NEVER go in config/ — only here / the environment (CONVENTIONS §8).

# LLM provider for the judgment nodes (fix / generate / evaluate / integrate).
# Only needed when model.provider = "anthropic". The "claude-code" backend
# shells out to the local `claude` CLI and needs no key; "fake" needs nothing.
ANTHROPIC_API_KEY=

# Optional config overrides (PYVERDEX_* shadow config/default.yaml).
# PYVERDEX_MODEL__PROVIDER=claude-code
